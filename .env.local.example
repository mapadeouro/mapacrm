# ─── Supabase ─────────────────────────────────────────────────────
# Encontre em: Supabase Dashboard > Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ─── Google Places API ────────────────────────────────────────────
# Ative em: console.cloud.google.com > APIs > Places API (New)
# Restrinja a chave: HTTP referrers → seu domínio + localhost

GOOGLE_PLACES_API_KEY=sua_google_places_key_aqui
